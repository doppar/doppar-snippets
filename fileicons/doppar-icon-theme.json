{
  "$schema": "vscode://schemas/icon-theme",
  "showLanguageModeIcons": true,
  "iconDefinitions": {
    "_file": {
      "iconPath": "../icons/file.svg"
    },
    "_folder": {
      "iconPath": "../icons/folder.svg"
    },
    "_folder_open": {
      "iconPath": "../icons/folder-open.svg"
    },
    "_odo_file": {
      "iconPath": "../icons/odo-file.svg"
    }
  },
  "file": "_file",
  "folder": "_folder",
  "folderExpanded": "_folder_open",
  "fileExtensions": {
    "odo.php": "_odo_file"
  },
  "languageIds": {
    "odo": "_odo_file"
  }
}
